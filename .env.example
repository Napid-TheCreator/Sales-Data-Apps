# Environment Variables untuk Sales Data Apps
# Salin file ini menjadi .env (untuk development lokal)
# Untuk production, isi di Vercel Dashboard → Settings → Environment Variables

# ============================================================
# SUPABASE CONFIGURATION
# Dapatkan dari: https://supabase.com/dashboard/project/[your-project]/settings/api
# ============================================================

# URL Project Supabase (contoh: https://abcdefghij.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/Public Key (aman untuk digunakan di frontend)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here
